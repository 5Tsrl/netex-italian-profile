	<!-- versioni di Service e figli con route modificato (presi da epip) (inizio) -->
	<xsd:complexType name="ServiceFrameL2_VersionStructure">
		<xsd:sequence>
			<xsd:group ref="VersionFrameGroup" minOccurs="0"/>
			<xsd:element ref="Network" minOccurs="0"/>
			<xsd:element ref="additionalNetworks" minOccurs="0"/>
			<xsd:element ref="directions" minOccurs="0"/>
			<xsd:element ref="routePoints" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Not necessarily required in EPIP, compare what is annotated for routes.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element ref="routeLinks" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Not necessarily required in EPIP, compare what is annotated for routes.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="routes" type="routesL2_RelStructure" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Not required in EPIP as data may not be available. However note that it is possible to align with SERVICE PATTERN, thus using the SCHEDULED STOP POINTs as a base for creating ROUTE POINTs, the POINTs IN JOURNEY
PATTERN for POINTs ON ROUTE, and the SERVICE LINKs for ROUTE LINKs </xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="lines" type="linesL2_RelStructure" minOccurs="0"/>
			<xsd:element ref="groupsOfLines" minOccurs="0"/>
			<xsd:element name="destinationDisplays" type="destinationDisplaysL2_RelStructure" minOccurs="0"/>
			<xsd:element name="scheduledStopPoints" type="scheduledStopPointsL2_RelStructure" minOccurs="0"/>
			<xsd:element name="serviceLinks" type="serviceLinksL2_RelStructure" minOccurs="0"/>
			<!-- aggiunto stopAreas per level 2 -->
			<xsd:element name="stopAreas" type="stopAreas_RelStructure" minOccurs="0"/>
			<xsd:element name="connections" type="connectionsL2Structure" minOccurs="0"/>
			<xsd:element ref="tariffZones" minOccurs="0"/>
			<xsd:element name="stopAssignments" type="stopAssignmentsL2Structure" minOccurs="0"/>
			<xsd:element name="journeyPatterns" type="journeyPatternsL2Structure" minOccurs="0"/>
			<xsd:element ref="notices" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="DataManagedObjectAttributeGroup"/>
	</xsd:complexType>
	<!-- versioni aggiornate per routes (inizio) -->
	<xsd:complexType name="routesL2_RelStructure">
		<xsd:choice maxOccurs="unbounded">
			<xsd:element name="Route" type="RouteL2_VersionStructure"/>
		</xsd:choice>
		<xsd:attributeGroup ref="ModificationSetAttributeGroup"/>
	</xsd:complexType>
	<xsd:complexType name="RouteL2_VersionStructure">
		<xsd:sequence>
			<xsd:group ref="LinkSequenceElementGroupL2"/>
			<xsd:element ref="LineRef" minOccurs="0"/>
			<xsd:element ref="DirectionType" minOccurs="0"/>
			<xsd:element ref="DirectionRef" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Reference to a DIRECTION.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="pointsInSequence" type="routePointsInSequence_RelStructure" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Ordered set of points making up a ROUTE.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="InverseRouteRef" type="RouteRefStructure" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Reference to the corresponding matching ROUTE in the  oppositte direction, if any.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
		<xsd:attributeGroup ref="DataManagedObjectAttributeGroup"/>
	</xsd:complexType>
	<xsd:group name="LinkSequenceElementGroupL2">
		<xsd:sequence>
			<xsd:group ref="DataManagedObjectElement_Group"/>
			<xsd:element ref="Name" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Name of LINK SEQUENCE.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- aggiunto ShortName per level 2 -->
			<xsd:element ref="ShortName" minOccurs="0"/>
			<!-- aggiunto Description per level 2 -->
			<xsd:element ref="Description" minOccurs="0"/>
			<xsd:element ref="Distance" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Units are as specified
for Frame. Default is SI Metres.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- aggiunto PrivateCode per level 2 -->
			<xsd:element ref="PrivateCode" minOccurs="0"/>
		</xsd:sequence>
	</xsd:group>
	<!-- versioni aggiornate per routes (fine) -->
	<!-- versioni aggiornate per lines (inizio) -->
	<xsd:complexType name="linesL2_RelStructure">
		<xsd:choice maxOccurs="unbounded">
			<xsd:element name="Line" type="LineL2Structure"/>
			<xsd:element name="FlexibleLine" type="FlexibleLineL2Structure">
				<xsd:annotation>
					<xsd:documentation>A group of FLEXIBLE ROUTEs of which is generally known to the public by a similar name or number and which have common booking arrangements.</xsd:documentation>
				</xsd:annotation>
