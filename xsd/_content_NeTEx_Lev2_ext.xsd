			<xsd:element name="ParkingLayout" type="ParkingLayoutEnumeration" minOccurs="0"/>
			<!-- aggiunto PrincipalCapacity da ParkingDetailsGroup in ParkingGroup -->
			<xsd:element name="PrincipalCapacity" type="xsd:integer" minOccurs="0"/>
			<xsd:element ref="TotalCapacity" minOccurs="0"/>
			<!-- aggiunto ProhibitedForHazardousMaterials da ParkingDetailsGroup in ParkingGroup -->
			<xsd:element name="ProhibitedForHazardousMaterials" type="xsd:boolean" default="true" minOccurs="0"/>
			<xsd:element ref="RechargingAvailable" minOccurs="0"/>
			<!-- aggiunto Secure da ParkingDetailsGroup in ParkingGroup -->
			<xsd:element name="Secure" type="xsd:boolean" minOccurs="0"/>
			<!-- aggiunto ParkingPaymentProcess da ParkingChargeGroup in ParkingGroup -->
			<xsd:element name="ParkingPaymentProcess" type="ParkingPaymentProcessListOfEnumerations" minOccurs="0"/>
			<!-- aggiunto ParkingReservation da ParkingChargeGroup in ParkingGroup -->
			<xsd:element name="ParkingReservation" type="ParkingReservationEnumeration" minOccurs="0"/>
			<!-- aggiunto parkingProperties da ParkingPassengerGroup in ParkingGroup -->
			<xsd:element name="parkingProperties" type="parkingProperties_RelStructure" minOccurs="0"></xsd:element>
			<!-- originariamente in ParkingGroup NeTEx (fine) -->
		</xsd:sequence>
		<xsd:attributeGroup ref="DataManagedObjectAttributeGroup"/>
	</xsd:complexType>
