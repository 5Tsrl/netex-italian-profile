	<xsd:complexType name="ParkingL2_VersionStructure">
		<xsd:sequence>
			<xsd:group ref="DataManagedObjectElement_Group"/>
			<xsd:element ref="Name" minOccurs="0"/>
			<!-- aggiunto ShortName da GroupOfEntitiesGroup NeTEx -->
			<xsd:element ref="ShortName" minOccurs="0"/>
			<xsd:element ref="Description" minOccurs="0"/>
			<xsd:element ref="Centroid" minOccurs="0"/>
			<!-- aggiunto Polygon da ZoneGroup NeTEx -->
			<xsd:element ref="gml:Polygon" minOccurs="0"/>
			<!-- aggiunto OperatorRef da SiteGroup dove c'è OrganisationRef -->
			<xsd:element ref="OperatorRef" minOccurs="0"/>
			<!-- aggiunto entrances da SiteGroup: usati i figli di Entrance -->
			<xsd:element name="entrances" type="siteEntrances_RelStructure" minOccurs="0"/>
			<xsd:element ref="Covered" minOccurs="0"/>
			<!-- originariamente in ParkingGroup NeTEx (inizio) -->
			<xsd:element ref="ParentSiteRef" minOccurs="0"/>
			<!-- aggiunto ParkingType da ParkingDetailsGroup in ParkingGroup -->
			<xsd:element name="ParkingType" type="ParkingTypeEnumeration" minOccurs="0"/>
			<xsd:element name="ParkingVehicleTypes" type="ParkingVehicleListOfEnumerations" minOccurs="0"/>
